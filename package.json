{
  "name": "yoom",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('.next', { recursive: true, force: true })\"",
    "clerk:sync-assets": "node scripts/sync-clerk-assets.mjs",
    "dev": "next dev --turbopack -p 3001",
    "dev:turbopack": "next dev --turbopack -p 3001",
    "dev:webpack": "next dev --webpack -p 3001",
    "build": "next build --turbopack",
    "build:webpack": "next build --webpack",
    "start": "next start -p 3001",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit --incremental false"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.0.6",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toast": "^1.2.15",
    "@stream-io/node-sdk": "^0.7.45",
    "@stream-io/video-react-sdk": "^1.34.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "mongodb": "^7.1.0",
    "next": "^16.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-tailwindcss": "^3.18.2",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3"
